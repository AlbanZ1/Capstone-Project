@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav auth-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link auth-user" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="fa-regular fa-circle-user" aria-hidden="true"></i>
            @User.Identity?.Name
        </a>
    </li>
    <li class="nav-item">
        <form class="auth-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-light btn-sm auth-login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
