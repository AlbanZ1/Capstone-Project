@model PaginatedList<Auctions.Models.Listing>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Auctions.SharedResource> L

@{
    var listingAction = ViewData["CurrentListingAction"] as string ?? "Index";
    var isMyListings = listingAction == "MyListings" || ViewData["MineOnly"] as bool? == true;
    ViewData["Title"] = isMyListings ? L["My Listings"] : L["Active Listings"];
    var categories = ViewData["Categories"] as SelectList;
}

@functions {
    private static string FormatCountdownDuration(TimeSpan remaining)
    {
        if (remaining <= TimeSpan.Zero)
        {
            return "Closed";
        }

        return $"{(int)remaining.TotalDays}d {remaining.Hours:00}h {remaining.Minutes:00}m {remaining.Seconds:00}s";
    }

    private static string FormatCountdownFallback(Listing listing)
    {
        if (listing.Status == AuctionStatus.Closed || listing.EndTime <= DateTime.Now)
        {
            return "Closed";
        }

        if (listing.Status == AuctionStatus.Pending && listing.StartTime > DateTime.Now)
        {
            return $"Starts in {FormatCountdownDuration(listing.StartTime - DateTime.Now)}";
        }

        return FormatCountdownDuration(listing.EndTime - DateTime.Now);
    }

    private static string GetStatusClass(AuctionStatus status)
    {
        return status switch
        {
            AuctionStatus.Active => "status-active",
            AuctionStatus.Pending => "status-pending",
            _ => "status-closed"
        };
    }

    private static string GetCategoryIcon(string categoryName)
    {
        return categoryName switch
        {
            "Electronics" => "fa-laptop",
            "Vehicles" => "fa-car-side",
            "Furniture" => "fa-couch",
            "Clothing" => "fa-shirt",
            "Books" => "fa-book-open",
            _ => "fa-box-open"
        };
    }
}

<section class="listing-intro">
    <div>
        <p class="section-kicker">@(isMyListings ? L["Seller dashboard"] : L["Live marketplace"])</p>
        <h1>@(isMyListings ? L["My Listings"] : L["Active Auctions"])</h1>
        <p>@(isMyListings ? L["Review your lots and keep track of their auction status."] : L["Search current lots, compare bids, and follow auctions while they are open."])</p>
    </div>
    @if(User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-accent">
            <i class="fa-solid fa-plus" aria-hidden="true"></i>
            @L["Create Listing"]
        </a>
    }
</section>

<section class="category-strip" aria-label="@L["Browse Categories"]">
    <div class="category-strip-header">
        <h2>@L["Browse Categories"]</h2>
        <a asp-action="@listingAction"
           asp-route-searchString="@ViewData["CurrentFilter"]"
           asp-route-statusFilter="@ViewData["CurrentStatusFilter"]"
           asp-route-viewMode="@ViewData["CurrentViewMode"]"
           asp-route-mineOnly="@ViewData["MineOnly"]">@L["All listings"]</a>
    </div>
    <div class="category-grid">
        @foreach(var category in categories ?? Enumerable.Empty<SelectListItem>())
        {
            <a asp-action="@listingAction"
               asp-route-categoryId="@category.Value"
               asp-route-searchString="@ViewData["CurrentFilter"]"
               asp-route-statusFilter="@ViewData["CurrentStatusFilter"]"
               asp-route-viewMode="@ViewData["CurrentViewMode"]"
               asp-route-mineOnly="@ViewData["MineOnly"]"
               class="category-link">
                <span aria-hidden="true"><i class="fa-solid @GetCategoryIcon(category.Text)"></i></span>
                @category.Text
            </a>
        }
    </div>
</section>

<form asp-action="@listingAction" method="get" class="market-filter">
    @if(ViewData["CurrentStatusFilter"] != null)
    {
        <input type="hidden" name="statusFilter" value="@ViewData["CurrentStatusFilter"]" />
    }
    @if(ViewData["CurrentViewMode"] != null)
    {
        <input type="hidden" name="viewMode" value="@ViewData["CurrentViewMode"]" />
    }
    @if(ViewData["MineOnly"] as bool? == true)
    {
        <input type="hidden" name="mineOnly" value="true" />
    }
    <div class="row g-3 align-items-end">
        <div class="col-lg-6">
            <label for="searchString" class="form-label">@L["Search listings"]</label>
            <div class="input-group">
                <span class="input-group-text" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" id="searchString" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="@L["Search by title"]" />
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <label for="categoryId" class="form-label">@L["Category"]</label>
            <select id="categoryId" name="categoryId" class="form-select" asp-items="@(categories)">
                <option value="">@L["All categories"]</option>
            </select>
        </div>
        <div class="col-md-6 col-lg-3 filter-actions">
            <button type="submit" class="btn btn-primary">@L["Filter"]</button>
            <a asp-action="@listingAction"
               asp-route-viewMode="@ViewData["CurrentViewMode"]"
               asp-route-mineOnly="@ViewData["MineOnly"]"
               class="btn btn-outline-secondary">@L["Clear"]</a>
        </div>
    </div>
</form>

<section class="auction-grid" aria-label="@L["Auction listings"]">
    @foreach(var listing in Model)
    {
        <article class="auction-card">
            <a asp-action="Details" asp-route-id="@listing.Id" class="auction-image-link" aria-label="View @listing.Title details">
                <img src="@listing.ImagePath" alt="@listing.Title" class="auction-image" />
            </a>
            <div class="auction-card-body">
                <div class="auction-meta-row">
                    <span class="category-pill">@(listing.Category?.Name ?? L["Uncategorized"])</span>
                    <span class="status-badge @GetStatusClass(listing.Status)">@L[listing.Status.ToString()]</span>
                </div>
                <h2><a asp-action="Details" asp-route-id="@listing.Id">@listing.Title</a></h2>
                <dl class="auction-stats">
                    <div>
                        <dt>@L["Current price"]</dt>
                        <dd>$@listing.CurrentPrice.ToString("N2")</dd>
                    </div>
                    <div>
                        <dt>@L["Time remaining"]</dt>
                        <dd class="countdown-label js-auction-countdown @(listing.Status == AuctionStatus.Closed ? "countdown-closed" : "")"
                            data-status="@listing.Status"
                            data-start-time="@listing.StartTime.ToString("yyyy-MM-ddTHH:mm:ss")"
                            data-end-time="@listing.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")"
                            aria-live="polite">
                            @FormatCountdownFallback(listing)
                        </dd>
                    </div>
                </dl>
                @if(listing.Bids != null)
                {
                    <p class="bid-count"><i class="fa-solid fa-signal" aria-hidden="true"></i> @listing.Bids.Count @L["bids"]</p>
                }
                <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-primary w-100">@L["View Details"]</a>
            </div>
        </article>
    }
</section>
@if(!Model.Any())
{
    <div class="empty-state">
        <i class="fa-regular fa-folder-open" aria-hidden="true"></i>
        <h2>@(isMyListings ? L["No listings found"] : L["No active listings found"])</h2>
        <p>@L["Try a broader search or clear the current category filter."]</p>
    </div>
}

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<nav class="pagination-shell" aria-label="Listing pages">
    <a asp-action="@listingAction"
        asp-route-pageNumber="@(Model.PageIndex - 1)"
        asp-route-searchString="@ViewData["CurrentFilter"]"
        asp-route-categoryId="@ViewData["CurrentCategoryId"]"
        asp-route-statusFilter="@ViewData["CurrentStatusFilter"]"
        asp-route-viewMode="@ViewData["CurrentViewMode"]"
        asp-route-mineOnly="@ViewData["MineOnly"]"
        class="btn btn-outline-secondary @prevDisabled">
        @L["Previous"]
    </a>
    <div class="page-status">
        @string.Format(L["Page {0} of {1}"], Model.PageIndex, Model.TotalPages)
    </div>
    <a asp-action="@listingAction"
        asp-route-pageNumber="@(Model.PageIndex + 1)"
        asp-route-searchString="@ViewData["CurrentFilter"]"
        asp-route-categoryId="@ViewData["CurrentCategoryId"]"
        asp-route-statusFilter="@ViewData["CurrentStatusFilter"]"
        asp-route-viewMode="@ViewData["CurrentViewMode"]"
        asp-route-mineOnly="@ViewData["MineOnly"]"
        class="btn btn-outline-secondary @nextDisabled">
        @L["Next"]
    </a>
</nav>
