@model Auctions.Models.Listing
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@inject UserManager<IdentityUser> userManager
@inject IStringLocalizer<Auctions.SharedResource> L

@{
    ViewData["Title"] = Model.Title;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserId = userManager.GetUserId(User);
    var bids = Model.Bids ?? Enumerable.Empty<Bid>();
    var comments = Model.Comments ?? Enumerable.Empty<Comment>();
    var isSeller = isAuthenticated && currentUserId == Model.IdentityUserId;
    var isWinner = isAuthenticated && currentUserId == Model.WinnerUserId;
    var isClosed = Model.Status == AuctionStatus.Closed;
    var canViewSellerContact = isSeller || (isClosed && isWinner);
    var sellerEmail = Model.User?.Email ?? "Not available";
    var sellerPhone = string.IsNullOrWhiteSpace(Model.ContactPhoneNumber) ? "Not available" : Model.ContactPhoneNumber;
    var finalPrice = Model.CurrentPrice;
    var minimumNextBid = Model.CurrentPrice + Model.MinimumBidIncrement;
    var listedByText = isSeller ? sellerEmail : "Private seller";
    var winnerDisplayText = isSeller && Model.WinnerUserId != null
        ? (Model.Winner?.Email ?? "Winner selected")
        : (Model.WinnerUserId == null ? "No winner" : "Winner selected");
}

@functions {
    private static string FormatCountdownDuration(TimeSpan remaining)
    {
        if (remaining <= TimeSpan.Zero)
        {
            return "Closed";
        }

        return $"{(int)remaining.TotalDays}d {remaining.Hours:00}h {remaining.Minutes:00}m {remaining.Seconds:00}s";
    }

    private static string FormatCountdownFallback(Listing listing)
    {
        if (listing.Status == AuctionStatus.Closed || listing.EndTime <= DateTime.Now)
        {
            return "Closed";
        }

        if (listing.Status == AuctionStatus.Pending && listing.StartTime > DateTime.Now)
        {
            return $"Starts in {FormatCountdownDuration(listing.StartTime - DateTime.Now)}";
        }

        return FormatCountdownDuration(listing.EndTime - DateTime.Now);
    }

    private static string GetStatusClass(AuctionStatus status)
    {
        return status switch
        {
            AuctionStatus.Active => "status-active",
            AuctionStatus.Pending => "status-pending",
            _ => "status-closed"
        };
    }
}

<section class="detail-heading">
    <a asp-action="Index" class="back-link"><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> @L["Active Listings"]</a>
    <div class="detail-title-row">
        <div>
            <p class="section-kicker">@(Model.Category?.Name ?? L["Uncategorized"])</p>
            <h1>@Model.Title</h1>
        </div>
        <span class="status-badge detail-status @GetStatusClass(Model.Status)">@L[Model.Status.ToString()]</span>
    </div>
</section>

@if(isAuthenticated && Model.Status == AuctionStatus.Closed)
{
    <div class="winner-banner">
        <i class="fa-solid fa-trophy" aria-hidden="true"></i>
        @if(Model.WinnerUserId == null)
        {
            <span>@L["Bidding is closed with no winner."]</span>
        }
        else if(Model.WinnerUserId == currentUserId)
        {
            <span>@L["Congratulations, you are the winner."]</span>
        }
        else if (currentUserId == Model.IdentityUserId)
        {
            <span>@string.Format(L["{0} is the winner."], Model.Winner?.Email ?? L["The winning bidder"])</span>
        }
        else
        {
            <span>@L["Bidding is closed. Winner details are private."]</span>
        }
    </div>
}

<section class="detail-layout">
    <div class="detail-main">
        <div class="detail-media">
            <img src="@Model.ImagePath" alt="@Model.Title" />
        </div>
        <article class="surface-panel detail-description">
            <h2>@L["Description"]</h2>
            <p>@Model.Description</p>
        </article>
    </div>

    <aside class="detail-sidebar">
        <section class="surface-panel price-panel">
            <div class="price-summary">
                <span>@L["Current price"]</span>
                <strong id="current-price">$@Model.CurrentPrice.ToString("N2")</strong>
            </div>
            <dl class="detail-facts">
                <div>
                    <dt>@L["Starting price"]</dt>
                    <dd>$@Model.StartingPrice.ToString("N2")</dd>
                </div>
                <div>
                    <dt>@L["Minimum bid increment"]</dt>
                    <dd>$@Model.MinimumBidIncrement.ToString("N2")</dd>
                </div>
                <div>
                    <dt>@L["Minimum next bid"]</dt>
                    <dd id="minimum-next-bid">$@minimumNextBid.ToString("N2")</dd>
                </div>
                <div>
                    <dt>@L["Time remaining"]</dt>
                    <dd class="countdown-label detail-countdown js-auction-countdown @(Model.Status == AuctionStatus.Closed ? "countdown-closed" : "")"
                        data-status="@Model.Status"
                        data-start-time="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm:ss")"
                        data-end-time="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")"
                        aria-live="polite">
                        @FormatCountdownFallback(Model)
                    </dd>
                </div>
                <div>
                    <dt>@L["Listed by"]</dt>
                    <dd>@(isSeller ? sellerEmail : L["Private seller"])</dd>
                </div>
                @if(Model.Status == AuctionStatus.Closed)
                {
                    <div>
                        <dt>@L["Winner"]</dt>
                        <dd>@winnerDisplayText</dd>
                    </div>
                }
            </dl>

            <div asp-validation-summary="All" class="validation-summary text-danger"></div>
            <div id="auction-extension-message"
                 class="alert alert-info py-2 @(ViewData["AuctionExtended"] as bool? == true ? "" : "d-none")"
                 role="status">
                @L["Auction extended by 5 minutes due to a last-minute bid."]
            </div>
            @if(isAuthenticated)
            {
                @if(Model.Status == AuctionStatus.Active)
                {
                    <form asp-action="AddBid" method="post" class="bid-form">
                        @Html.AntiForgeryToken()
                        <label for="bid-price-input" class="form-label">@L["Your bid"]</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input id="bid-price-input" class="form-control" type="number" min="@minimumNextBid" step="0.01" name="Price" placeholder="@minimumNextBid.ToString("N2")" />
                            <input type="hidden" name="ListingId" class="form-control" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary">@L["Place Bid"]</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="bid-form">
                        <label for="bid-price-input" class="form-label">@L["Your bid"]</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input id="bid-price-input" class="form-control" type="number" min="@minimumNextBid" step="0.01" name="Price" placeholder="@minimumNextBid.ToString("N2")" disabled />
                            <button disabled type="submit" class="btn btn-primary">@L["Place Bid"]</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bid-form">
                    <label for="bid-price-input" class="form-label">@L["Your bid"]</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input id="bid-price-input" class="form-control" type="number" min="@minimumNextBid" step="0.01" name="Price" placeholder="@minimumNextBid.ToString("N2")" />
                        <button disabled type="submit" class="btn btn-primary">@L["Sign in to Bid"]</button>
                    </div>
                </div>
            }

            <div class="live-bid-panel">
                <p>@L["Bids submitted"] <strong id="bid-count">@bids.Count()</strong></p>
                <div id="latest-bid" aria-live="polite">@L["Live bid updates appear here."]</div>
            </div>

            @if(isAuthenticated && currentUserId == Model.IdentityUserId && Model.Status != AuctionStatus.Closed)
            {
                <a asp-action="CloseBidding" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100">@L["Close Bidding"]</a>
            }
        </section>

        <section class="surface-panel seller-contact-panel">
            <h2>@L["Seller Contact"]</h2>
            @if(canViewSellerContact)
            {
                <dl class="detail-facts">
                    <div>
                        <dt>@L["Email"]</dt>
                        <dd>@sellerEmail</dd>
                    </div>
                    <div>
                        <dt>@L["Phone"]</dt>
                        <dd>@sellerPhone</dd>
                    </div>
                </dl>
            }
            else
            {
                <p>@L["Seller contact details are visible only to the winner after the auction ends."]</p>
            }
        </section>

        @if(isSeller && isClosed)
        {
            <section class="surface-panel seller-closed-panel">
                <h2>@L["Closed Auction"]</h2>
                @if(Model.WinnerUserId != null)
                {
                    <dl class="detail-facts">
                        <div>
                            <dt>@L["Winner email"]</dt>
                            <dd>@(Model.Winner?.Email ?? "Not available")</dd>
                        </div>
                        <div>
                            <dt>@L["Final price"]</dt>
                            <dd>$@finalPrice.ToString("N2")</dd>
                        </div>
                    </dl>
                }
                else
                {
                    <p>@L["Auction ended with no bids."]</p>
                }
            </section>
        }

        @if(isWinner && isClosed)
        {
            <section class="surface-panel winner-checkout-panel">
                <h2>@L["Winner Checkout"]</h2>
                <dl class="detail-facts">
                    <div>
                        <dt>@L["Seller email"]</dt>
                        <dd>@sellerEmail</dd>
                    </div>
                    <div>
                        <dt>@L["Seller phone"]</dt>
                        <dd>@sellerPhone</dd>
                    </div>
                    <div>
                        <dt>@L["Final price"]</dt>
                        <dd>$@finalPrice.ToString("N2")</dd>
                    </div>
                </dl>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="btn btn-primary js-payment-option" data-payment-message="@L["Cash payment selected. Please contact the seller using the provided email or phone number and arrange pickup/payment."]">@L["Cash"]</button>
                    <button type="button" class="btn btn-outline-secondary js-payment-option" data-payment-message="@L["Card payment is currently under development."]">@L["Card"]</button>
                </div>
                <p id="payment-choice-message" class="mt-3 mb-0" aria-live="polite"></p>
            </section>
        }

        @if(isSeller)
        {
            <section class="surface-panel bid-history">
                <h2>@L["Bid History"]</h2>
                @if(bids.Any())
                {
                    <ol>
                        @foreach(var bid in bids.OrderByDescending(b => b.Price))
                        {
                            <li>
                                <span>@(bid.User?.UserName ?? L["Auction user"])</span>
                                <strong>$@bid.Price.ToString("N2")</strong>
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <p>@L["No bids submitted yet."]</p>
                }
            </section>
        }
    </aside>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (() => {
            const listingId = @Model.Id;
            const currentPrice = document.getElementById("current-price");
            const minimumNextBid = document.getElementById("minimum-next-bid");
            const bidCount = document.getElementById("bid-count");
            const bidInput = document.getElementById("bid-price-input");
            const latestBid = document.getElementById("latest-bid");
            const countdown = document.querySelector(".detail-countdown");
            const extensionMessage = document.getElementById("auction-extension-message");
            const paymentMessage = document.getElementById("payment-choice-message");
            const currency = new Intl.NumberFormat(undefined, {
                style: "currency",
                currency: "USD"
            });

            document.querySelectorAll(".js-payment-option").forEach((button) => {
                button.addEventListener("click", () => {
                    if (paymentMessage) {
                        paymentMessage.textContent = button.dataset.paymentMessage || "";
                    }
                });
            });

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/auctionHub")
                .withAutomaticReconnect()
                .build();

            const joinListing = () => connection.invoke("JoinListing", listingId);

            connection.on("BidPlaced", (bid) => {
                currentPrice.textContent = currency.format(bid.newCurrentPrice);
                bidCount.textContent = bid.bidCount;

                if (bidInput) {
                    bidInput.min = bid.minimumNextBid.toString();
                    bidInput.placeholder = bid.minimumNextBid.toFixed(2);
                }

                if (minimumNextBid) {
                    minimumNextBid.textContent = currency.format(bid.minimumNextBid);
                }

                if (bid.auctionExtended && bid.updatedEndTime && countdown) {
                    countdown.dataset.endTime = bid.updatedEndTime;
                    countdown.dataset.status = "Active";
                    countdown.classList.remove("countdown-closed");

                    if (extensionMessage) {
                        extensionMessage.classList.remove("d-none");
                        extensionMessage.textContent = "@L["Auction extended by 5 minutes due to a last-minute bid."]";
                    }
                }

                const bidTime = new Date(bid.bidTime).toLocaleString();
                latestBid.textContent = `@L["Latest bid:"] ${bid.bidderDisplayName} @L["bid"] ${currency.format(bid.bidAmount)} @L["at"] ${bidTime}.`;
            });

            connection.onreconnected(() => {
                joinListing().catch(error => console.error(error));
            });

            connection.start()
                .then(joinListing)
                .catch(error => console.error(error));
        })();
    </script>
}

<section class="surface-panel comments-panel">
    <div class="comments-grid">
        @if(isAuthenticated)
        {
            <form asp-action="AddComment" method="post" class="comment-form">
                @Html.AntiForgeryToken()
                <h2>@L["Add Comment"]</h2>
                <label for="comment-content" class="form-label">@L["Message"]</label>
                <textarea id="comment-content" class="form-control" aria-label="@L["Comment message"]" name="Content" rows="4"></textarea>
                <input type="hidden" name="IdentityUserId" class="form-control" value="@currentUserId" />
                <input type="hidden" name="ListingId" class="form-control" value="@Model.Id" />
                <input type="submit" class="btn btn-primary" value="@L["Post Comment"]" />
            </form>
        }
        else
        {
            <div class="comment-form">
                <h2>@L["Add Comment"]</h2>
                <label for="comment-content" class="form-label">@L["Message"]</label>
                <textarea id="comment-content" class="form-control" aria-label="@L["Comment message"]" name="Content" rows="4"></textarea>
                <input type="submit" disabled class="btn btn-primary" value="@L["Sign in to Comment"]" />
            </div>
        }

        <div class="comment-list">
            <h2>@L["Comments"]</h2>
            @if(comments.Any())
            {
                @foreach(var comment in comments)
                {
                    <article class="comment-card">
                        <p>@comment.Content</p>
                        <span>@(comment.User?.UserName ?? L["Auction user"])</span>
                    </article>
                }
            }
            else
            {
                <p>@L["No comments yet."]</p>
            }
        </div>
    </div>
</section>
