@model Auctions.Models.Listing
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> userManager

@{
    ViewData["Title"] = Model.Title;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUserId = userManager.GetUserId(User);
    var bids = Model.Bids ?? Enumerable.Empty<Bid>();
    var comments = Model.Comments ?? Enumerable.Empty<Comment>();
}

@functions {
    private static string FormatTimeRemaining(DateTime endTime)
    {
        var remaining = endTime - DateTime.Now;
        if (remaining <= TimeSpan.Zero)
        {
            return "Ended";
        }

        if (remaining.TotalDays >= 1)
        {
            return $"{(int)remaining.TotalDays}d {remaining.Hours}h remaining";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"{remaining.Hours}h {remaining.Minutes}m remaining";
        }

        return $"{remaining.Minutes}m remaining";
    }

    private static string GetStatusClass(AuctionStatus status)
    {
        return status switch
        {
            AuctionStatus.Active => "status-active",
            AuctionStatus.Pending => "status-pending",
            _ => "status-closed"
        };
    }
}

<section class="detail-heading">
    <a asp-action="Index" class="back-link"><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Active listings</a>
    <div class="detail-title-row">
        <div>
            <p class="section-kicker">@(Model.Category?.Name ?? "Uncategorized")</p>
            <h1>@Model.Title</h1>
        </div>
        <span class="status-badge detail-status @GetStatusClass(Model.Status)">@Model.Status</span>
    </div>
</section>

@if(isAuthenticated && Model.Status == AuctionStatus.Closed)
{
    <div class="winner-banner">
        <i class="fa-solid fa-trophy" aria-hidden="true"></i>
        @if(Model.WinnerUserId == null)
        {
            <span>Bidding is closed with no winner.</span>
        }
        else if(Model.WinnerUserId == currentUserId)
        {
            <span>Congratulations, you are the winner.</span>
        }
        else if (currentUserId == Model.IdentityUserId)
        {
            <span>@Model.Winner?.UserName is the winner.</span>
        }
        else
        {
            <span>Bidding is closed. Winner: @Model.Winner?.UserName</span>
        }
    </div>
}

<section class="detail-layout">
    <div class="detail-main">
        <div class="detail-media">
            <img src="@Model.ImagePath" alt="@Model.Title" />
        </div>
        <article class="surface-panel detail-description">
            <h2>Description</h2>
            <p>@Model.Description</p>
        </article>
    </div>

    <aside class="detail-sidebar">
        <section class="surface-panel price-panel">
            <div class="price-summary">
                <span>Current price</span>
                <strong id="current-price">$@Model.CurrentPrice.ToString("N2")</strong>
            </div>
            <dl class="detail-facts">
                <div>
                    <dt>Starting price</dt>
                    <dd>$@Model.StartingPrice.ToString("N2")</dd>
                </div>
                <div>
                    <dt>Time remaining</dt>
                    <dd>@FormatTimeRemaining(Model.EndTime)</dd>
                </div>
                <div>
                    <dt>Listed by</dt>
                    <dd>@(Model.User?.UserName ?? "Auction user")</dd>
                </div>
                @if(Model.Status == AuctionStatus.Closed)
                {
                    <div>
                        <dt>Winner</dt>
                        <dd>@(Model.Winner?.UserName ?? "No winner")</dd>
                    </div>
                }
            </dl>

            <div asp-validation-summary="All" class="validation-summary text-danger"></div>
            @if(isAuthenticated)
            {
                @if(Model.Status == AuctionStatus.Active)
                {
                    <form asp-action="AddBid" method="post" class="bid-form">
                        @Html.AntiForgeryToken()
                        <label for="bid-price-input" class="form-label">Your bid</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input id="bid-price-input" class="form-control" type="number" min="@(Model.CurrentPrice + 1)" step="1" name="Price" placeholder="@Model.CurrentPrice.ToString("N2")" />
                            <input type="hidden" name="ListingId" class="form-control" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary">Place Bid</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="bid-form">
                        <label for="bid-price-input" class="form-label">Your bid</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input id="bid-price-input" class="form-control" type="number" min="@(Model.CurrentPrice + 1)" step="1" name="Price" placeholder="@Model.CurrentPrice.ToString("N2")" disabled />
                            <button disabled type="submit" class="btn btn-primary">Place Bid</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bid-form">
                    <label for="bid-price-input" class="form-label">Your bid</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input id="bid-price-input" class="form-control" type="number" min="@(Model.CurrentPrice + 1)" step="1" name="Price" placeholder="@Model.CurrentPrice.ToString("N2")" />
                        <button disabled type="submit" class="btn btn-primary">Sign in to Bid</button>
                    </div>
                </div>
            }

            <div class="live-bid-panel">
                <p>Bids submitted <strong id="bid-count">@bids.Count()</strong></p>
                <div id="latest-bid" aria-live="polite">Live bid updates appear here.</div>
            </div>

            @if(isAuthenticated && currentUserId == Model.IdentityUserId && Model.Status != AuctionStatus.Closed)
            {
                <a asp-action="CloseBidding" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100">Close Bidding</a>
            }
        </section>

        @if(isAuthenticated && currentUserId == Model.IdentityUserId)
        {
            <section class="surface-panel bid-history">
                <h2>Bid History</h2>
                @if(bids.Any())
                {
                    <ol>
                        @foreach(var bid in bids.OrderByDescending(b => b.Price))
                        {
                            <li>
                                <span>@(bid.User?.UserName ?? "Auction user")</span>
                                <strong>$@bid.Price.ToString("N2")</strong>
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <p>No bids submitted yet.</p>
                }
            </section>
        }
    </aside>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (() => {
            const listingId = @Model.Id;
            const currentPrice = document.getElementById("current-price");
            const bidCount = document.getElementById("bid-count");
            const bidInput = document.getElementById("bid-price-input");
            const latestBid = document.getElementById("latest-bid");
            const currency = new Intl.NumberFormat(undefined, {
                style: "currency",
                currency: "USD"
            });

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/auctionHub")
                .withAutomaticReconnect()
                .build();

            const joinListing = () => connection.invoke("JoinListing", listingId);

            connection.on("BidPlaced", (bid) => {
                currentPrice.textContent = currency.format(bid.newCurrentPrice);
                bidCount.textContent = bid.bidCount;

                if (bidInput) {
                    bidInput.min = (bid.newCurrentPrice + 1).toString();
                    bidInput.placeholder = bid.newCurrentPrice.toFixed(2);
                }

                const bidTime = new Date(bid.bidTime).toLocaleString();
                latestBid.textContent = `Latest bid: ${bid.bidderDisplayName} bid ${currency.format(bid.bidAmount)} at ${bidTime}.`;
            });

            connection.onreconnected(() => {
                joinListing().catch(error => console.error(error));
            });

            connection.start()
                .then(joinListing)
                .catch(error => console.error(error));
        })();
    </script>
}

<section class="surface-panel comments-panel">
    <div class="comments-grid">
        @if(isAuthenticated)
        {
            <form asp-action="AddComment" method="post" class="comment-form">
                @Html.AntiForgeryToken()
                <h2>Add Comment</h2>
                <label for="comment-content" class="form-label">Message</label>
                <textarea id="comment-content" class="form-control" aria-label="Comment message" name="Content" rows="4"></textarea>
                <input type="hidden" name="IdentityUserId" class="form-control" value="@currentUserId" />
                <input type="hidden" name="ListingId" class="form-control" value="@Model.Id" />
                <input type="submit" class="btn btn-primary" value="Post Comment" />
            </form>
        }
        else
        {
            <div class="comment-form">
                <h2>Add Comment</h2>
                <label for="comment-content" class="form-label">Message</label>
                <textarea id="comment-content" class="form-control" aria-label="Comment message" name="Content" rows="4"></textarea>
                <input type="submit" disabled class="btn btn-primary" value="Sign in to Comment" />
            </div>
        }

        <div class="comment-list">
            <h2>Comments</h2>
            @if(comments.Any())
            {
                @foreach(var comment in comments)
                {
                    <article class="comment-card">
                        <p>@comment.Content</p>
                        <span>@(comment.User?.UserName ?? "Auction user")</span>
                    </article>
                }
            }
            else
            {
                <p>No comments yet.</p>
            }
        </div>
    </div>
</section>
