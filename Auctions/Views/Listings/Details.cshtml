@model Auctions.Models.Listing
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> userManager

@{
    ViewData["Title"] = "Details";
}

@functions {
    private static string FormatTimeRemaining(DateTime endTime)
    {
        var remaining = endTime - DateTime.Now;
        if (remaining <= TimeSpan.Zero)
        {
            return "Ended";
        }

        if (remaining.TotalDays >= 1)
        {
            return $"{(int)remaining.TotalDays}d {remaining.Hours}h remaining";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"{remaining.Hours}h {remaining.Minutes}m remaining";
        }

        return $"{remaining.Minutes}m remaining";
    }
}

@if(User.Identity.IsAuthenticated)
{
    @if(Model.Status == AuctionStatus.Closed)
    {
        @if(Model.WinnerUserId == null)
        {
            <h5>Bidding is closed with no winner.</h5>
        }
        else if(Model.WinnerUserId == userManager.GetUserId(User))
        {
            <h5>Congratulations, you are the winner!</h5>
        }
        else if (userManager.GetUserId(User) == Model.User.Id)
        {
            <h5>@Model.Winner?.UserName is the winner!</h5>
        }
        else
        {
            <h5>Bidding is closed! Winner: @Model.Winner?.UserName</h5>
        }
    }
}

<h4 style="text-align: center">@Model.Title</h4>
<div class="container" style="background-color: rgba(138, 129, 133, 0.6); margin-top: 50px; margin-bottom: 50px; padding: 20px; border-radius: 10px;">
    <div class="row">
        <div class="col col-xs-6 col-lg-5">
            <img src="@Model.ImagePath" style="width: 100%; max-height: 60vh;" />
        </div>
        <div class="col col-xs-6 col-lg-7">
            <div>@Model.Description</div>
            <div>Starting Price: $@Model.StartingPrice.ToString("N2")</div>
            <div>
                Current Price:
                <span id="current-price">$@Model.CurrentPrice.ToString("N2")</span>
            </div>
            <div>Status: @Model.Status</div>
            <div>Time Remaining: @FormatTimeRemaining(Model.EndTime)</div>
            @if(Model.Status == AuctionStatus.Closed)
            {
                <div>Winner: @(Model.Winner?.UserName ?? "No winner")</div>
            }
            <div asp-validation-summary="All" class="text-danger"></div>
            @if(User.Identity.IsAuthenticated)
            {
                @if(Model.Status == AuctionStatus.Active)
                {
                    <form asp-action="AddBid" method="post">
                        @Html.AntiForgeryToken()
                        <div>
                            Bid: $ <input id="bid-price-input" type="number" min="@(Model.CurrentPrice + 1)" step="1" name="Price" placeholder="@Model.CurrentPrice.ToString("N2")"/>
                            <input type="hidden" name="ListingId" class="form-control" value="@Model.Id" />
                            <input type="submit" class="btn btn-primary" />
                        </div>
                    </form>
                }
                else
                {
                    <div>
                        Bid: $ <input id="bid-price-input" type="number" min="@(Model.CurrentPrice + 1)" step="1" name="Price" placeholder="@Model.CurrentPrice.ToString("N2")" disabled />
                        <input disabled type="submit" class="btn btn-primary" />
                    </div>
                }
                <p>Bids submitted: <span id="bid-count">@Model.Bids.Count</span></p>
                <br>
                @if(userManager.GetUserId(User) == Model.User.Id)
                {
                    @foreach(var bid in Model.Bids)
                    {
                        <ul style="list-style-type: none;">
                            @bid.User.UserName bidded $@bid.Price.ToString("N2").
                        </ul>
                    }
                }
            }
            else
            {
                <div>
                    Bid: $ <input id="bid-price-input" type="number" min="@(Model.CurrentPrice + 1)" step="1" name="Price" placeholder="@Model.CurrentPrice.ToString("N2")" />
                    <input disabled type="submit" class="btn btn-primary" />
                </div>
                <p>Bids submitted: <span id="bid-count">@Model.Bids.Count</span></p>
            }

            <div id="latest-bid" aria-live="polite"></div>
            <div>Listed by: @Model.User.UserName</div>

            @if(User.Identity.IsAuthenticated)
            {
                @if(userManager.GetUserId(User) == Model.User.Id)
                {
                    @if(Model.Status != AuctionStatus.Closed)
                    {
                        <a asp-action="CloseBidding" asp-route-id="@Model.Id">Close Bidding</a>
                    }
                    
                }
            }

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (() => {
            const listingId = @Model.Id;
            const currentPrice = document.getElementById("current-price");
            const bidCount = document.getElementById("bid-count");
            const bidInput = document.getElementById("bid-price-input");
            const latestBid = document.getElementById("latest-bid");
            const currency = new Intl.NumberFormat(undefined, {
                style: "currency",
                currency: "USD"
            });

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/auctionHub")
                .withAutomaticReconnect()
                .build();

            const joinListing = () => connection.invoke("JoinListing", listingId);

            connection.on("BidPlaced", (bid) => {
                currentPrice.textContent = currency.format(bid.newCurrentPrice);
                bidCount.textContent = bid.bidCount;

                if (bidInput) {
                    bidInput.min = (bid.newCurrentPrice + 1).toString();
                    bidInput.placeholder = bid.newCurrentPrice.toFixed(2);
                }

                const bidTime = new Date(bid.bidTime).toLocaleString();
                latestBid.textContent = `Latest bid: ${bid.bidderDisplayName} bid ${currency.format(bid.bidAmount)} at ${bidTime}.`;
            });

            connection.onreconnected(() => {
                joinListing().catch(error => console.error(error));
            });

            connection.start()
                .then(joinListing)
                .catch(error => console.error(error));
        })();
    </script>
}

<br>

@if(User.Identity.IsAuthenticated)
{
    <div class="container">
        <form asp-action="AddComment" method="post">
            <h6>Add comment</h6>
            <textarea class="form-control" aria-label="With textarea" name="Content" style="width: 40%; vertical-align: top;"></textarea>
            <input type="hidden" name="IdentityUserId" class="form-control" value="@userManager.GetUserId(User)" />
            <input type="hidden" name="ListingId" class="form-control" value="@Model.Id" />
            <input type="submit" class="btn btn-primary" style="display: inline-block; margin-top: 10px;" />
        </form>
    </div>
}
else
{
    <div class="container">
            <h6>Add comment</h6>
            <textarea class="form-control" aria-label="With textarea" name="Content" style="width: 40%; vertical-align: top;"></textarea>
            <input type="submit" disabled class="btn btn-primary" style="display: inline-block; margin-top: 10px;" />
    </div>
}
<br>
<div class="container">
    <h6>Comments</h6>
    @foreach(var comment in Model.Comments)
    {
        <div style="border: 1px solid lightgray; margin: 10px; padding: 10px; border-radius: 10px; width: 40%;">
            <p>@comment.Content - @comment.User.UserName</p>
        </div>
    }
</div>
