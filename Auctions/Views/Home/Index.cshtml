@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Auctions.SharedResource> L
@{
    ViewData["Title"] = L["Auction Marketplace"];
}

<section class="marketplace-home">
    <div class="home-content">
        <p class="section-kicker">@L["Live auction marketplace"]</p>
        <h1>@L["Discover listings worth bidding on."]</h1>
        <p>@L["Browse active auctions by category, watch live price changes, and open each lot for the full details before bidding."]</p>
        <div class="home-actions">
            <a asp-controller="Listings" asp-action="Index" class="btn btn-primary">@L["Browse Active Listings"]</a>
            @if(User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Listings" asp-action="Create" class="btn btn-accent">@L["Create Listing"]</a>
            }
        </div>
    </div>
    <nav class="home-categories" aria-label="@L["Featured categories"]">
        <a asp-controller="Listings" asp-action="Index" asp-route-categoryId="1"><i class="fa-solid fa-laptop" aria-hidden="true"></i> @L["Electronics"]</a>
        <a asp-controller="Listings" asp-action="Index" asp-route-categoryId="2"><i class="fa-solid fa-car-side" aria-hidden="true"></i> @L["Vehicles"]</a>
        <a asp-controller="Listings" asp-action="Index" asp-route-categoryId="3"><i class="fa-solid fa-couch" aria-hidden="true"></i> @L["Furniture"]</a>
        <a asp-controller="Listings" asp-action="Index" asp-route-categoryId="4"><i class="fa-solid fa-shirt" aria-hidden="true"></i> @L["Clothing"]</a>
        <a asp-controller="Listings" asp-action="Index" asp-route-categoryId="5"><i class="fa-solid fa-book-open" aria-hidden="true"></i> @L["Books"]</a>
        <a asp-controller="Listings" asp-action="Index" asp-route-categoryId="6"><i class="fa-solid fa-box-open" aria-hidden="true"></i> @L["Other"]</a>
    </nav>
</section>
